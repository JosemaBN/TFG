generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ---- Un solo almacén (toda la app y la API asumen un único Warehouse) ----

model Warehouse {
  id        String   @id @default(cuid())
  name      String
  address   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  stock ProductStock[]
}

/// Áreas disponibles para el catálogo (además de las que salgan de productos ya creados).
model CatalogArea {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())
}

/// Tipos disponibles para el catálogo (además de los que salgan de productos ya creados).
model CatalogTipo {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())
}

model Product {
  id          String   @id @default(cuid())
  /// Código interno autoincremental (no editable en la app)
  sku         Int      @unique @default(autoincrement())
  marca       String?
  name        String
  description String?
  /// Categoría: zona funcional del material (p. ej. sonido, iluminación)
  area        String?
  /// Categoría: tipo de equipo o pieza (p. ej. mesa, micro, cable)
  tipo        String?
  /// Orden manual dentro del mismo área/tipo (flechas en listado Materiales).
  sortOrder   Int      @default(0)
  /// Columna REP en plantilla (unidades; editable solo en plantilla vía API dedicada).
  repQty      Int      @default(0)
  /// Inventario total de la empresa para este material (columna INV en plantilla).
  companyInventoryQty Int @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  stock             ProductStock[]
  movements         Movement[]
  eventProductPlans EventProductPlan[]
}

// Stock actual en el único almacén (producto ↔ almacén, 1 almacén)
model ProductStock {
  productId   String
  warehouseId String
  quantity    Int      @default(0)
  updatedAt   DateTime @updatedAt

  product   Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  warehouse Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Cascade)

  @@id([productId, warehouseId])
}

// ---- Evento (obra/proyecto) al que sale el material y del que vuelve ----

model Event {
  id         String   @id @default(cuid())
  name       String
  code       String?  @unique
  /// Parámetros de la planilla / ficha del evento
  poblacion  String?
  lugar      String?
  reference  String?
  notes      String?
  startDate  DateTime?
  endDate    DateTime?
  /// Horas del día (formato HH:mm, p. ej. desde input type="time")
  horaMontaje    String? @db.VarChar(8)
  horaPrueba     String? @db.VarChar(8)
  horaComienzo   String? @db.VarChar(8)
  horaFin        String? @db.VarChar(8)
  horaDesmontaje String? @db.VarChar(8)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  movements         Movement[]
  eventProductPlans EventProductPlan[]
}

/// Cantidad planificada (Ud) por evento y material en la plantilla
model EventProductPlan {
  eventId    String
  productId  String
  plannedQty Int      @default(0)
  updatedAt  DateTime @updatedAt

  event   Event   @relation(fields: [eventId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@id([eventId, productId])
}

enum MovementType {
  SALIDA  // material sale del almacén hacia el evento
  ENTRADA // material vuelve del evento al almacén
}

// Many-to-many Event ↔ Product: cada fila es un movimiento (salida o entrada) de un producto en un evento
model Movement {
  id        String       @id @default(cuid())
  eventId   String
  productId String
  type      MovementType // SALIDA = almacén → evento, ENTRADA = evento → almacén
  quantity  Int          // siempre positivo; el tipo indica dirección
  notes     String?
  createdAt DateTime     @default(now())

  event   Event   @relation(fields: [eventId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([eventId])
  @@index([productId])
  @@index([createdAt])
}
