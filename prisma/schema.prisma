generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ---- Único almacén y catálogo ----

model Warehouse {
  id        String   @id @default(cuid())
  name      String
  address   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  stock ProductStock[]
}

model Product {
  id          String   @id @default(cuid())
  sku         String   @unique
  name        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  stock    ProductStock[]
  movements Movement[]
}

// Stock actual en el único almacén (producto ↔ almacén, 1 almacén)
model ProductStock {
  productId   String
  warehouseId String
  quantity    Int      @default(0)
  updatedAt   DateTime @updatedAt

  product   Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  warehouse Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Cascade)

  @@id([productId, warehouseId])
}

// ---- Evento (obra/proyecto) al que sale el material y del que vuelve ----

model Event {
  id         String   @id @default(cuid())
  name       String
  code       String?  @unique
  reference  String?
  notes      String?
  startDate  DateTime?
  endDate    DateTime?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  movements Movement[]
}

enum MovementType {
  SALIDA  // material sale del almacén hacia el evento
  ENTRADA // material vuelve del evento al almacén
}

// Many-to-many Event ↔ Product: cada fila es un movimiento (salida o entrada) de un producto en un evento
model Movement {
  id        String       @id @default(cuid())
  eventId   String
  productId String
  type      MovementType // SALIDA = almacén → evento, ENTRADA = evento → almacén
  quantity  Int          // siempre positivo; el tipo indica dirección
  notes     String?
  createdAt DateTime     @default(now())

  event   Event   @relation(fields: [eventId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([eventId])
  @@index([productId])
  @@index([createdAt])
}
