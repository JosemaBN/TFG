# Opcional: si está definida, el front llama directo a esta URL (sin proxy de Vite).
# En desarrollo, si la omites, las peticiones van a /__api/... y Vite reenvía a Express.
# VITE_API_URL=http://127.0.0.1:3000

# Solo desarrollo: destino del proxy cuando no usas VITE_API_URL (por defecto 127.0.0.1:3000).
# VITE_DEV_PROXY_TARGET=http://127.0.0.1:3000
